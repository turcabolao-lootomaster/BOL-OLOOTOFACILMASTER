rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: master, admin, vendedor, cliente)
    //   - totalPoints: number (optional, default 0)
    //   - createdAt: timestamp (required)
    //
    // Collection: contests
    // Document ID: contestId
    // Fields:
    //   - number: number (required)
    //   - status: string (required, enum: aberto, encerrado)
    //   - draws: list of objects (required)
    //   - prizes: map (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: bets
    // Document ID: betId
    // Fields:
    //   - userId: string (required)
    //   - userName: string (required)
    //   - contestId: string (required)
    //   - contestNumber: number (optional)
    //   - numbers: list (required, size 10)
    //   - status: string (required, enum: pendente, validado, rejeitado)
    //   - sellerCode: string (optional)
    //   - hits: list (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') &&
             time < request.time + duration.value(5, 'm');
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == 'turcabolao@gmail.com' && request.auth.token.email_verified == true) ||
        hasRole('admin') || 
        hasRole('master')
      );
    }
    
    function isMaster() {
      return isAuthenticated() && (
        (request.auth.token.email == 'turcabolao@gmail.com' && request.auth.token.email_verified == true) ||
        hasRole('master')
      );
    }

    function isSeller() {
      return hasRole('vendedor');
    }

    function isSellerOwner(sellerCode) {
      return isSeller() && 
             getUserData(request.auth.uid).linkedSellerCode == sellerCode;
    }

    // Validator Functions
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('email' in data) || data.email is string) &&
             (!('whatsapp' in data) || data.whatsapp is string) &&
             (!('accessCode' in data) || data.accessCode is string) &&
             data.role in ['master', 'admin', 'vendedor', 'cliente'] &&
             (data.totalPoints == null || data.totalPoints is int);
    }

    function isValidBet(data) {
      return data.keys().hasAll(['userId', 'userName', 'contestId', 'numbers', 'status']) &&
             data.userId is string && data.userId.size() < 128 &&
             data.userName is string && data.userName.size() < 100 &&
             data.contestId is string && data.contestId.size() < 128 &&
             data.numbers is list && data.numbers.size() == 10 &&
             data.status in ['pendente', 'validado', 'rejeitado'] &&
             (!('sellerCode' in data) || (data.sellerCode is string && data.sellerCode.size() < 50)) &&
             (!('betName' in data) || (data.betName is string && data.betName.size() < 100));
    }

    function isValidContest(data) {
      return data.keys().hasAll(['number', 'status', 'draws']) &&
             data.number is number &&
             data.status in ['aberto', 'em_andamento', 'encerrado'] &&
             data.draws is list && data.draws.size() <= 3 &&
             (!('prizes' in data) || data.prizes is map) &&
             (!('prizeConfig' in data) || data.prizeConfig is map);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                      (isOwner(userId) || userId.startsWith('wa_') || userId.startsWith('code_')) &&
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'cliente' || isAdmin());
                      
      allow update: if isAuthenticated() && 
                      (
                        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.totalPoints == resource.data.totalPoints) || 
                        isAdmin() ||
                        (
                          // Allow updating UID if WhatsApp or Code matches (Custom Login)
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']) &&
                          (
                            (resource.data.whatsapp != null && request.resource.data.whatsapp == resource.data.whatsapp) ||
                            (resource.data.accessCode != null && request.resource.data.name == resource.data.name && request.resource.data.accessCode == resource.data.accessCode)
                          )
                        )
                      );
                      
      allow delete: if isMaster();
    }

    match /contests/{contestId} {
      allow read: if true;
      allow create: if isAdmin() && isValidContest(request.resource.data);
      allow update: if isAdmin() && isValidContest(request.resource.data);
      allow delete: if isMaster();
    }

    match /bets/{betId} {
      // Allow reading for participants view, but only for validated bets or own bets.
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      (request.resource.data.userId == request.auth.uid || isAdmin()) && 
                      request.resource.data.status == 'pendente' &&
                      isValidBet(request.resource.data);
                      
      allow update: if (isAdmin() || (isSellerOwner(resource.data.sellerCode) && request.resource.data.sellerCode == resource.data.sellerCode)) && 
                      isValidBet(request.resource.data);
      
      allow delete: if isAdmin() || isSellerOwner(resource.data.sellerCode);
    }

    match /sellers/{sellerId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/sellers/$(resource.data.sellerId)) &&
        get(/databases/$(database)/documents/sellers/$(resource.data.sellerId)).data.userId == request.auth.uid
      );
      allow create: if isAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/sellers/$(request.resource.data.sellerId)) &&
        get(/databases/$(database)/documents/sellers/$(request.resource.data.sellerId)).data.userId == request.auth.uid
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rankings/{rankingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sellerRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // Open to interested participants
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
