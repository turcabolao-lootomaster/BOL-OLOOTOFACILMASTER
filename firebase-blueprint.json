{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and ranking points",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "accessCode": { "type": "string" },
        "role": { "type": "string", "enum": ["master", "admin", "vendedor", "cliente"] },
        "totalPoints": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Bet": {
      "title": "Bet",
      "description": "A bet made by a user in a contest",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "contestId": { "type": "string" },
        "contestNumber": { "type": "integer" },
        "numbers": { "type": "array", "items": { "type": "integer" }, "minItems": 10, "maxItems": 10 },
        "status": { "type": "string", "enum": ["pendente", "validado", "rejeitado"] },
        "sellerCode": { "type": "string" },
        "hits": { "type": "array", "items": { "type": "integer" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "contestId", "numbers", "status"]
    },
    "Contest": {
      "title": "Contest",
      "description": "A Lotofácil contest with 3 draws",
      "type": "object",
      "properties": {
        "number": { "type": "integer" },
        "status": { "type": "string", "enum": ["aberto", "em_andamento", "encerrado"] },
        "startDate": { "type": "string" },
        "startTime": { "type": "string" },
        "betPrice": { "type": "number" },
        "draws": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "number": { "type": "integer" },
              "status": { "type": "string", "enum": ["pendente", "concluido"] },
              "results": { "type": "array", "items": { "type": "integer" } }
            }
          }
        },
        "prizes": {
          "type": "object",
          "properties": {
            "draw1": { "type": "string" },
            "draw2": { "type": "string" },
            "draw3": { "type": "string" },
            "rapidinha1": { "type": "string" },
            "rapidinha2": { "type": "string" },
            "rankeada": { "type": "string" }
          }
        },
        "prizeConfig": {
          "type": "object",
          "properties": {
            "pctRapidinha": { "type": "number" },
            "pctChampion": { "type": "number" },
            "pctVice": { "type": "number" },
            "pctSeller": { "type": "number" },
            "pctAdmin": { "type": "number" },
            "pctReserve": { "type": "number" },
            "fixed10PtsDraw1": { "type": "number" },
            "fixed10PtsDraw2": { "type": "number" },
            "fixed10PtsDraw3": { "type": "number" },
            "fixed25PlusTotal": { "type": "number" },
            "fixed27PlusTotal": { "type": "number" }
          }
        },
        "publicLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "status", "draws"]
    },
    "NickReservation": {
      "title": "Nick Reservation",
      "description": "Reservation of a participant name to prevent collisions",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "reservedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId"]
    },
    "Seller": {
      "title": "Seller",
      "description": "Seller profile and sales stats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "code": { "type": "string" },
        "commissionPct": { "type": "number" },
        "totalSales": { "type": "integer" },
        "totalCommission": { "type": "number" },
        "pixKey": { "type": "string" }
      },
      "required": ["userId", "code", "commissionPct"]
    },
    "Commission": {
      "title": "Commission",
      "description": "Commission record for a bet",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "betId": { "type": "string" },
        "amount": { "type": "number" },
        "paid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "betId", "amount", "paid"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Ranking": {
      "title": "Ranking",
      "description": "Global ranking for a participant (betName + sellerCode)",
      "type": "object",
      "properties": {
        "betName": { "type": "string" },
        "sellerCode": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this name" },
        "totalPoints": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["betName", "totalPoints"]
    },
    "SellerRequest": {
      "title": "Seller Request",
      "description": "Request for a new seller account",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "requestedCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pendente", "aprovado", "rejeitado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "whatsapp", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/contests/{contestId}": {
      "schema": "Contest",
      "description": "Contests management"
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "User bets"
    },
    "/sellers/{sellerId}": {
      "schema": "Seller",
      "description": "Seller profiles"
    },
    "/commissions/{commissionId}": {
      "schema": "Commission",
      "description": "Commission records"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings"
    },
    "/rankings/{rankingId}": {
      "schema": "Ranking",
      "description": "Global ranking records"
    },
    "/sellerRequests/{requestId}": {
      "schema": "SellerRequest",
      "description": "Requests for new seller accounts"
    },
    "/nick_reservations/{key}": {
      "schema": "NickReservation",
      "description": "Participant name reservations"
    }
  }
}
